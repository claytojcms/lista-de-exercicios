#include <stdio.h>
#include <stdlib.h>


void bubbleSort_otimizado(int v[], int n, int ordem) {
    int comparacoes = 0;
    int trocas = 0;
    for(int i=0; i< n ;i++){
       int houvetroca =0 ;
        for(int j=0 ; j<n-i-1 ; j++){
    comparacoes++;
            if(v[j]>v[j+1] && ordem==1){
                int temp= v[j+1];
                v[j+1]= v[j];
                v[j]= temp;
                trocas ++;
                houvetroca=1;
            }
              if(v[j]<v[j+1] && ordem==-1){
                int temp= v[j+1];
                v[j+1]= v[j];
                v[j]= temp;
                trocas ++;
                houvetroca=1;
            }
        }
        if(houvetroca==0)
            break;
    }
     printf("Otimizado:\n Trocas=%d  comparacoes:%d\n",trocas,comparacoes);
}


void imprimirVetor(int v[], int n) {
    for(int i = 0; i < n; i++)
        printf("%d ", v[i]);
    printf("\n");
}

int main() {
    int n=6;
    int ordem;
    int repetidos[]={10,6,7,10,1,6};
    int mistura[]={10,-2,7,8,1,-6};
    int vetor_unico[1]={5};
    int vetor_vazio[]={};

    printf("qual a ordem que voce quer:\n1-crescente\n-1-decrescente\n");
    scanf("%d",&ordem);

      printf("\nVETOR ORIGINAL REPETIDOS:\n");
    imprimirVetor(repetidos,n);
    bubbleSort_otimizado(repetidos,n,ordem);
    printf("VETOR ORDENADO:\n");
    imprimirVetor(repetidos,n);

    printf("\nVETOR ORIGINAL MISTURA:\n");
    imprimirVetor(mistura,n);
    bubbleSort_otimizado(mistura,n,ordem);
    printf("VETOR ORDENADO:\n");
    imprimirVetor(mistura,n);

     printf("\nVETOR ORIGINAL UNICO:\n");
    imprimirVetor(vetor_unico,1);
    bubbleSort_otimizado(vetor_unico,1,ordem);
    printf("VETOR ORDENADO:\n");
    imprimirVetor(vetor_unico,1);

     printf("\nVETOR ORIGINAL VAZIO:\n");
    imprimirVetor(vetor_vazio,0);
    bubbleSort_otimizado(vetor_vazio,0,ordem);
    printf("VETOR ORDENADO:\n");
    imprimirVetor(vetor_vazio,0);



    return 0;
}
