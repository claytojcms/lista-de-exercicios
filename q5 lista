#include <stdio.h>
#include <stdlib.h>


void bubbleSort_otimizado(int v[], int n, int ordem) {
    int comparacoes = 0;
    int trocas = 0;
    for(int i=0; i< n ;i++){
       int houvetroca =0 ;
        for(int j=0 ; j<n-i-1 ; j++){
    comparacoes++;
            if(v[j]>v[j+1] && ordem==1){
                int temp= v[j+1];
                v[j+1]= v[j];
                v[j]= temp;
                trocas ++;
                houvetroca=1;
            }
              if(v[j]<v[j+1] && ordem==-1){
                int temp= v[j+1];
                v[j+1]= v[j];
                v[j]= temp;
                trocas ++;
                houvetroca=1;
            }
        }
        if(houvetroca==0)
            break;
    }
     printf("Otimizado:\n Trocas=%d  comparacoes:%d\n",trocas,comparacoes);
}


void imprimirVetor(int v[], int n) {
    for(int i = 0; i < n; i++)
        printf("%d ", v[i]);
    printf("\n");
}

int main() {
    int n=6;
    int ordem;
    int dados[]={10,2,7,8,1,6};
    printf("qual a ordem que voce quer:\n1-crescente\n-1-decrescente\n");
    scanf("%d",&ordem);
    printf("VETOR ORIGINAL:\n");
    imprimirVetor(dados,n);
    bubbleSort_otimizado(dados,n,ordem);
    printf("VETOR ORDENADO:\n");
    imprimirVetor(dados,n);


    return 0;
}

